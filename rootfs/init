#!/bin/sh

# 1. 파일 시스템 마운트
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

# 2. 사장님 전용 부팅 로고 (L-MOS Edition)
clear
echo "#################################################"
echo "#          WELCOME TO LUNA MINING OS            #"
echo "#          Version 1.1.0 (SSH & Mining)         #"
echo "#          SSH Password: luna123                #"
echo "#################################################"
echo ""
echo "[INFO] Initializing Kernel Services..."
sleep 1

# 3. 네트워크 초기화 (DHCP로 IP 할당)
echo "[INFO] Bringing up Network (DHCP)..."
ip link set eth0 up # 대부분의 유선 랜카드 이름은 eth0입니다.
dhclient eth0 & # 백그라운드에서 IP를 할당받습니다.
sleep 3
echo "[INFO] Current IP: $(ip addr show eth0 | grep 'inet ' | awk '{print $2}')"

# 4. SSH 서버 가동
echo "[INFO] Starting SSH Server (Port 22)..."
/etc/init.d/ssh start

# 5. L-MOS 채굴기(XMRig) 백그라운드 가동
echo "[INFO] Launching Luna Miner (DOGE Strategy)..."
/bin/xmrig --config=/etc/xmrig/config.json > /tmp/miner.log 2>&1 &
echo "[SUCCESS] Miner is running!"

# 6. 사용자 쉘 실행
echo ""
echo "Luna OS Ready. (Type 'tail -f /tmp/miner.log' for stats)"
exec /bin/sh
